[
{{- $pages := .Site.RegularPages -}}
{{- range $i, $p := $pages -}}
  {{- if $i }},{{ end -}}
  {
    "title": {{ $p.Title | jsonify }},
    "url": {{ $p.RelPermalink | jsonify }},
    "date": {{ $p.Date | time.Format "2006-01-02T15:04:05Z07:00" | jsonify }},
    "summary": {{ $p.Summary | jsonify }}
  }
{{- end -}}
]